# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5434/content_service

# Redis
REDIS_URL=redis://localhost:6381/0

# JWT (paste your Auth Service public key here)
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
YOUR_PUBLIC_KEY_HERE
-----END PUBLIC KEY-----"
JWT_ALGORITHM=RS256

# Storage
MEDIA_BUCKET=kalosphere-content
MEDIA_MAX_SIZE_MB=50
CDN_BASE_URL=http://localhost:9002/kalosphere-content

# AWS (for S3-compatible storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_ENDPOINT_URL=http://localhost:9002

# Events
EVENT_STREAM_PREFIX=kalosphere
CONSUMER_GROUP=content-service

# Postgres (used by docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=content_service

# MinIO (used by docker-compose)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Rate Limiting
RATE_LIMIT_POSTS_PER_DAY=10
RATE_LIMIT_LIKES_PER_HOUR=100
RATE_LIMIT_COMMENTS_PER_HOUR=30

# Image Processing
IMAGE_MAX_DIMENSION=2048
THUMBNAIL_DIMENSION=400

# App
DEBUG=true
