# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/profile_service

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT (paste your Auth Service public key here)
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
YOUR_PUBLIC_KEY_HERE
-----END PUBLIC KEY-----"
JWT_ALGORITHM=RS256

# Storage
AVATAR_BUCKET=kalosphere-avatars
AVATAR_MAX_SIZE_MB=5
CDN_BASE_URL=http://localhost:9000/kalosphere-avatars

# AWS (for S3-compatible storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_ENDPOINT_URL=http://localhost:9000

# Events
EVENT_STREAM_PREFIX=kalosphere
CONSUMER_GROUP=profile-service

# App
DEBUG=true
